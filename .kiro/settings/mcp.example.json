{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": [
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "<YOUR_GITHUB_PAT>"
      },
      "disabled": false,
      "autoApprove": [
        "get_issue",
        "list_issues",
        "search_issues"
      ]
    }
  }
}

